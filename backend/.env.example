# SQLite database path
# В Docker: /data/db/errant_fox.db
# Локально: ./errant_fox.sqlite
DATABASE_URL=/data/db/errant_fox.db

# Secret key for signing JWT tokens — use a long random string in production
JWT_SECRET=

# SeaweedFS / S3-compatible storage
# S3_ENDPOINT — full URL of the S3 API, e.g. http://192.168.1.100:8333
S3_ENDPOINT=http://your-truenas-ip:8333

# S3 bucket name (must already exist in SeaweedFS)
S3_BUCKET=videos

# S3 access and secret keys (create in SeaweedFS admin → S3 → IAM)
S3_ACCESS_KEY=
S3_SECRET_KEY=

# S3 region — SeaweedFS ignores this but the SDK requires a value
S3_REGION=us-east-1

# Directory for storing generated video preview frames (created automatically)
# В Docker эти пути задаются в docker-compose.yml через environment
PREVIEWS_DIR=/data/previews

# Directory for storing user avatar files (created automatically)
AVATARS_DIR=/data/avatars

# Port for the backend server
SERVER_PORT=8080

# Frontend origin — used for CORS (must match your frontend URL exactly)
# В продакшене: http://your-truenas-ip
FRONTEND_ORIGIN=http://your-truenas-ip
